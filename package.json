{
    "name": "jigyasu",
    "version": "1.0.0",
    "private": true,
    "description": "Jigyasu - Install Wonder. Unified offline-first educational platform.",
    "engines": {
        "node": ">=20.x"
    },
    "packageManager": "pnpm@8.15.5",
    "scripts": {
        "dev": "pnpm --parallel --filter !backend -r dev",
