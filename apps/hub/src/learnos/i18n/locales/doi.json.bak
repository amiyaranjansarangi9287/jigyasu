    "climateadult": {
      "co_concentration": "सी. ओ. 2 सांद्रता",
      "ppm": "पीपीएम",
      "co_molecules_trap_infrared_rad": "CO2 अणु इंफ्रारेड रेडिएशन गी फँसांदे न जेह्ड़ा नेईं तां अंतरिक्ष च नस्सी जाई सकदा ऐ। मते CO2 दा मतलब मता फंसी दी गर्मी ऐ। एह् भौतिकी ऐ, सियासत नेईं-स्वांते अरहेनियस ने 1896 च एह् गिनती कीती ही।",
      "the_carbon_you_exhale_becomes_": "तुंʼदे आसेआ छोड़ी दित्ता जाने आह्ला कार्बन किश दिनें च इक पोदे दा हिस्सा बनी जंदा ऐ। पर जीवाश्म ईंधनें गी जलाने कन्नै पैदा होने आह्ला कार्बन नमीं कार्बन गी जोड़दा ऐ जेह्ड़ा लक्खें बʼरें थमां जमीन दे खʼल्ल बंद हा।",
      "history_of_the_idea": "विचार दा इतिहास",
      "john_tyndall_discovered_the_gr": "जॉन टिंडल ने 1859 च ग्रीनहाउस असर दी खोज कीती। अरहेनियस ने इसगी 1896 च जीवाश्म ईंधनें कन्नै जुड़ेआ। चार्ल्स कीलिंग ने 1958 च CO2 गी नापना शुरू कीता-ओह्दे परैंत्त थमां \"कीलिंग कर्व\" च बेरोक-टोक बाद्धा होआ ऐ।"
    },
    "daynightadult": {
      "rotation_speed": "घूर्णन गति",
      "x": "x",
      "the_sun_doesn_t_rise_earth_rot": "सूरज \"उगदा\" नेईं ऐ-धरती घुमदी ऐ, तुसें गी सूरज दी रोशनी च आह्न्नी जंदी ऐ। इस कोपरनिकस अंतर्दृष्टि गी मंजूर करने च सदियां लगियां की जे साडा अंतर्ज्ञान आखदा ऐ जे सूरज चलदी ऐ।",
      "earth_rotates_once_every_24_ho": "धरती हर 24 घैंटे च इक बारी घुमदी ऐ। समां खेतर मजूद न की जे बक्ख-बक्ख थाह्र बक्ख-बक्ख समें पर सूरज दा सामना करदे न। जेट लैग तुंʼदा शरीर इक नमीं घूर्णन स्थिति गी फड़ना ऐ।",
      "history_of_the_idea": "विचार दा इतिहास",
      "aryabhata_in_499_ad_proposed_e": "आर्यभट्ट ने 499 ईस्वी च धरती गी घुमाने दा प्रस्ताव दित्ता। कोपरनिकस ने 1543 च यूरोप च इस बिचार गी परतियै जीवत कीता। गैलीलियो गी एह्दे समर्थन आस्तै घर च नजरबंद करी दित्ता गेआ हा। एह् बिचार जे साडा रोजमर्रा दा अनुभव इक भरम होई सकदा ऐ, क्रांतिकारी हा।"
    },
    "dnanatureadult": {
      "the_human_genome_has_3_billion": "इन्सान दे जीनोम च 3 अरब अधार जोड़े होंदे न। जेकर तुस उʼनें गी अक्षरें दे रूप च छापदे ओ, तां एह् 200 फोन बुकें गी भरोचेगा। अजें के प्रोटीन आस्तै छड़ा तकरीबन 2 फीसदी कोड-बाकी गी कदें \"जंक डीएनए\" आखेआ जंदा हा पर एह् बिलकुल बेकार नेईं ऐ।",
      "mrna_vaccines_work_by_giving_y": "एम. आर. एन. ए. टीके तुंʼदी कोशिकाएं गी वायरस दा इक हानिरहित टुकड़ा बनाने आस्तै निर्देश (इʼयै कोड च) देियै कम्म करदे न। तुंʼदी प्रतिरक्षा प्रणाली एह्दे शा सिखदी ऐ। कोड कुंजी ऐ।",
      "history_of_the_idea": "विचार दा इतिहास",
      "watson_and_crick_discovered_th": "वाटसन ते क्रिक ने 1953 च संरचना दी खोज कीती। रोजालिंड फ्रैंकलिन दी एक्स-रे क्रिस्टलोग्राफी लाजमी ही-उʼनें गी अपने जीवनकाल च तकरीबन कोई श्रेय नेईं दित्ता गेआ। ह्यूमन जीनोम प्रोजेक्ट 2003 च पूरा होआ। सी. आर. आई. एस. पी. आर. जीन संपादन 2012 च आया।"
    },
    "electricityadult": {
      "electrons_don_t_zoom_through_w": "इलेक्ट्रान पानी जनेही तारें दे राहें ज़ूम नेईं करदे न। ओह् हौले-हौले-मिलीमीटर प्रति सैक्केड चलांदे न। पर सिग्नल लेई जाने आह्ली विद्युत चुम्बकीय तरंग तकरीबन रोशनी दी गति कन्नै जातरा करदी ऐ।",
      "your_charger_gets_warm_because": "तुंʼदा चार्जर गर्म होई जंदा ऐ की जे इलेक्ट्रान परमाणुएं (प्रतिरोध) कन्नै टकराई जंदे न। ओह् बर्बाद होने आह्ली ऊर्जा गर्मी बनी जंदी ऐ। उच्च प्रतिरोध दा मतलब ऐ मती गर्मी, मती ऊर्जा दा नुकसान।",
      "history_of_the_idea": "विचार दा इतिहास",
      "franklin_thought_electricity_f": "फ्रैंकलिन दा मन्नना हा जे बिजली सकारात्मक कोला नकारात्मक बक्खी बगदी ऐ। ओह् गलत हे-इलेक्ट्रान दुए पासेआ बगदे न। असीं अजें बी उंʼदी परंपरा दा इस्तेमाल करदे आं। फैराडे ते ओम ने तुसें गी सर्किटें गी शासत करने आह्ले नियम दिंदे न।"
    },
    "evolutionadult": {
      "humans_didn_t_descend_from_chi": "इन्सान चिम्पांएं थमां पैदा नेईं होए हे। इन्सान ते चिम्पां इक बराबर पूर्वज सांझे करदे न। एह् बड़ा गै बक्ख ऐ-असी चचेरे भाई आं, बंशज नेईं।",
      "the_60_dna_shared_with_bananas": "केले दे कन्नै सांझा कीता गेआ 60 फीसदी डी. ऐन्न. ए. जीवन दी मूल मशीनरी-कोशिका विभाजन, ऊर्जा उत्पादन-दा प्रतिनिधित्व करदा ऐ जेह्ड़ा अरबां बʼरें च नेईं बदला ऐ।",
      "history_of_the_idea": "विचार दा इतिहास",
      "darwin_gathered_evidence_for_2": "डार्विन ने 1859 च \"ऑन द ओरिजिन ऑफ स्पीशीज\" छापने शा पैह्लें 20एं बʼरें तक्कर सबूत जुटाए। उʼनें गी पता हा जे एह् विवादास्पद होग। ओह् सब्र-दाह्वे कोला पैह्लें सबूत-विज्ञान आस्तै इक माडल बने दा ऐ।"
    },
    "floatsinkadult": {
      "a_ship_floats_because_its_hull": "समुंदरी जत्था तैंतर करदा ऐ की जे ओह्दे पतवार च अपने वजन दे बराबर पानी होंदा ऐ। इस्पात दी सूई ठोस होंदी ऐ-एह् मती मात्तरा च पानी गी विस्थापित नेईं करी सकदी, इस करियै एह् डुब्बी जंदी ऐ।",
      "archimedes_principle_the_buoya": "आर्किमिडीज़ दा सिद्धांतः उत्प्लावन बल विस्थापित द्रव दे भार दे बराबर होंदा ऐ। आकार पदार्थ दी तुलना च मता म्हत्तवपूर्ण ऐ।",
      "history_of_the_idea": "विचार दा इतिहास",
      "legend_says_archimedes_discove": "किंवदंती च आखेआ गेआ ऐ जे आर्किमिडीज़ ने न्हाने दे दुरान इʼनें दी खोज कीती ते सिराक्यूस च नग्गे होई \"यूरेका!\" आखदे होई दौड़े, पर एह् कथा मिथक होई सकदी ऐ, पर सिद्धांत 2,300 बʼरे पराना ऐ।"
    },
    "foodchainadult": {
      "only_10_of_energy_transfers_be": "छड़ा 10 फीसदी ऊर्जा स्तरें दे बिच्च स्थानांतरित होंदी ऐ। इक बाघ गी 100 हिरणें गी खाने दी लोड़ होंदी ऐ तां जे उʼनें हिरनें गी 10,000 पौधें थमां शक्ति मिली सकै। इस करियै शीर्श परभक्षी बिरले होंदे न।",
