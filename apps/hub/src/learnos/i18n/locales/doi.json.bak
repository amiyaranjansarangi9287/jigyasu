      "concept_gossip": {
        "zero-infinity": {
          "title": "ज़ीरो ते अनंत",
          "concept1": "शून्य (0)",
          "concept2": "अनंतता (≤)",
          "messages": [
            {
              "sender": 1,
              "text": "[DOI] Hey Infinity. Everyone thinks I am nothing. But without me, math falls apart."
            },
            {
              "sender": 2,
              "text": "[DOI] I know the feeling. They think I am a number. I'm actually a direction, an endless journey."
            },
            {
              "sender": 1,
              "text": "[DOI] True. If someone tries to divide by me, I break the universe."
            },
            {
              "sender": 2,
              "text": "[DOI] And if they try to add 1 to me, nothing changes. We are the ultimate rule-breakers."
            },
            {
              "sender": 1,
              "text": "[DOI] Indian mathematicians gave me a symbol — a dot, then a circle (shunya). What about you?"
            },
            {
              "sender": 2,
              "text": "[DOI] John Wallis gave me this ∞ shape in 1655. But the idea of endlessness is ancient."
            }
          ]
        },
        "gravity-entropy": {
          "title": "गुरुत्वाकर्षण ते एन्ट्रापी",
          "concept1": "गुरुत्वाकर्षण",
          "concept2": "एन्ट्रापी",
          "messages": [
            {
              "sender": 1,
              "text": "[DOI] I bring things together. I build stars, planets, and galaxies."
            },
            {
              "sender": 2,
              "text": "[DOI] And I tear them apart. I am the reason things decay and spread out."
            },
            {
              "sender": 1,
              "text": "[DOI] We are complete opposites. I create order out of chaos."
            },
            {
              "sender": 2,
              "text": "[DOI] But in the end, I always win. The universe is moving toward maximum chaos."
            },
            {
              "sender": 1,
              "text": "[DOI] Unless... a black hole? I crush everything into a singularity."
            },
            {
              "sender": 2,
              "text": "[DOI] Even black holes evaporate over time (Hawking radiation). Told you I win."
            }
          ]
        },
        "dna-rna": {
          "title": "डी. ऐन्न. ए. ते आर. ऐन्न. ए.",
          "concept1": "डी. ऐन्न. ए.",
          "concept2": "आर. एन. ए.",
          "messages": [
            {
              "sender": 1,
              "text": "[DOI] I am the master blueprint. I hold the code for life safely in the nucleus."
            },
            {
              "sender": 2,
              "text": "[DOI] Yeah, but you never leave the nucleus. You're just a massive, secure hard drive."
            },
            {
              "sender": 1,
              "text": "[DOI] Security is important! I'm a stable double helix."
            },
            {
              "sender": 2,
              "text": "[DOI] I'm the one who actually gets things done. I read your code, go to the ribosomes, and build the proteins."
            },
            {
              "sender": 1,
              "text": "[DOI] True, you are the messenger. Without you, I'm just static information."
            },
            {
              "sender": 2,
              "text": "[DOI] Exactly. You're the architect, but I'm the construction worker."
            }
          ]
        }
      },
