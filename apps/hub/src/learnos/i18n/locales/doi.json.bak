    "audience": {
      "0": {
        "heading": "ओह् ञ्याणा जेह्ड़ा ट्यूशन दा खर्च वहन नेईं करी सकदा",
        "body": "बिहार जां ओडिशा दे इक सरकारी स्कूल च इक 9एं बʼरें दा ञ्याणा। इक ने एंड्राइड फोन सांझा कीता। कोई कोचिंग नेईं। जिग्यासू उʼनें गी इक रोगी, दृश्य शिक्षक दिंदा ऐ जेह्ड़ा दिन च 24 घैंटे उपलब्ध होंदा ऐ। मुफ्त। उंʼदी भाशा च।"
      },
      "1": {
        "heading": "अजीबो-गरीब बालिग जि'नें अपना मौका गोआई ओड़ेआ",
        "body": "इक 38एं ब'रें दा जेह्ड़ा हमेशां एह् समझना चाह्न्नां जे आकास़ नीला की ऐ। कोई उमर लेबल नेईं ऐ। कोई मतेहान दा दबाऽ नेईं ऐ। कोई शर्म नेईं ऐ। बस इक सुंदर व्याख्या जेह्दे बारे च ओह् हमेशां सोचदे हे।"
      },
      "2": {
        "heading": "माता-पिता अपने ञ्याणे दे कन्नै गै सिखदे न",
        "body": "हैदराबाद च इक मां, क्लास 8 च पढ़ी-लिखी। उंʼदी धीऽ क्लास 6 च ऐ। ओह् अपनी गति कन्नै तेलुगु च नेहा गै अवधारणा सिखदी ऐ। हून ओह् रात दे खाने च प्रकाश संश्लेषण पर चर्चा करी सकदे न।"
      },
      "3": {
        "heading": "पैह्ली पीढ़ी दा शिक्षार्थी",
        "body": "राजस्थान दे इक ग्रांS च इक 16एं बʼरें दा ञ्याणा। परोआर च पैह्ला जेह्ड़ा 10मीं कक्षा च पुजदा ऐ। कोई कोचिंग संस्थान नेईं ऐ। जिज्ञासा ऑफ़लाइन कम्म करदी ऐ। स्कूल दे कंप्यूटर पर डाउनलोड कीती जंदी ऐ। घर च पढ़ाई कीती जंदी ऐ।"
      },
      "4": {
        "heading": "दादा-दादी जेह्ड़े जुड़ना चाह्न्नां",
        "body": "अपने पोतरे दे रूपै च इक गै अवधारणा सिखना। ऐप दे जरि'यै उʼनें गी प्रोत्साहक संदेश भेजना। सांझी खोज दे जरि'यै इक बंधन बनाना।"
      }
    }
  },
