# ═══════════════════════════════════════════════════════════════════════════════
# Jigyasu Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Sign up free at https://sentry.io
# → Create a new project → Choose "Browser JavaScript"
# → Copy the DSN from Project Settings > Client Keys
#
# When VITE_SENTRY_DSN is set, errors in production are automatically reported.
# When left empty (local dev), Sentry is silently disabled — no crashes.
VITE_SENTRY_DSN=https://your-public-dsn@o0.ingest.sentry.io/0

# ── API Backend ───────────────────────────────────────────────────────────────
# Leave EMPTY for local development — Vite's dev server proxies /api routes
# to localhost:3001 automatically (see vite.config.ts server.proxy).
#
# Set to your deployed backend URL for staging and production.
# Example: https://api.jigyasu.app
VITE_API_BASE_URL=
